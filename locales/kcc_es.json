    "Disable processing": "No procesar",
    "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Unchecked - next to source<br/></span>Place output files next to source files</p><p><span style=\" font-weight:600; text-decoration: underline;\">Indeterminate - folder next to source<br/></span>Place output files in a folder next to source files</p><p><span style=\" font-weight:600; text-decoration: underline;\">Checked - Custom<br/></span>Place output files in custom directory specified by right button</p></body></html>": "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Sin marcar - Mismo sitio<br/></span>Crea junto al origen.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Gris - Subcarpeta<br/></span>Carpeta junto al origen.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Marcado - Custom<br/></span>Carpeta personalizada.</p></body></html>",
    "Output Folder": "Dir Salida",
    "<html><head/><body><p>Use this to select the default output directory.</p></body></html>": "<html><head/><body><p>Elegir directorio destino.</p></body></html>",
    "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Unchecked - Don't use metadata Title<br/></span>Write default title.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Indeterminate - Add metadata Title to the default schema<br/></span>Write default title with Title from ComicInfo.xml or other embedded metadata.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Checked - Use metadata Title only<br/></span>Write Title from ComicInfo.xml or other embedded metadata.</p></body></html>": "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Sin marcar - No usar metadatos<br/></span>Título normal.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Gris - Usar ambos<br/></span>Título normal y del XML.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Marcado - Solo Metadatos<br/></span>Solo título del XML.</p></body></html>",
    "Metadata Title": "Título de Meta",
    "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Unchecked - BW only<br/></span>Only autocontrast bw pages. Ignored for pages where near blacks or whites don't exist.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Indeterminate - Disabled<br/></span>Disable autocontrast</p><p><span style=\" font-weight:600; text-decoration: underline;\">Checked - BW and Color<br/></span>BW and color images will be autocontrasted. Ignored for pages where near blacks or whites don't exist.</p></body></html>": "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Sin marcar - Solo BW<br/></span>Autocontraste para B/N.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Gris - Desactiva<br/></span>Sin autocontraste.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Marcado - BW y Color<br/></span>Contraste todos.</p></body></html>",
    "Autocontrast": "Autocontraste",
    "Use the PDF image extraction method from KCC 8 and earlier.\n": "Útil para extraer PDF difíciles viejos.\n",
    "PDF Legacy Extract": "Extraer PDF Antiguo",
    "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Unchecked - Nothing<br/></span>Images smaller than device resolution will not be resized.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Indeterminate - Stretching<br/></span>Images smaller than device resolution will be resized. Aspect ratio will be not preserved.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Checked - Upscaling<br/></span>Images smaller than device resolution will be resized. Aspect ratio will be preserved.</p></body></html>": "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Sin marcar - Nada<br/></span>Sin redimensiones.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Gris - Estirar<br/></span>Estirar tamaño.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Marcado - Ampliar<br/></span>Ampliar conservando ratios.</p></body></html>",
    "Stretch/Upscale": "Estirar/Ampliar",
    "<html><head/><body><p><span style=\" font-weight:700; text-decoration: underline;\">Unchecked<br/></span>Maximal output file size is 100 MB for Webtoon, 400 MB for others before split occurs.</p><p><span style=\" font-weight:700; text-decoration: underline;\">Checked</span><br/>Output file size specified in &quot;Chunk size MB&quot; before split occurs.</p></body></html>": "<html><head/><body><p><span style=\" font-weight:700; text-decoration: underline;\">Sin marcar<br/></span>Sin cortes extras.</p><p><span style=\" font-weight:700; text-decoration: underline;\">Marcado</span><br/>Corta al tamaño custom.</p></body></html>",
    "Chunk size": "Límite MB",
    "<html><head/><body><p style='white-space:pre'><span style=\" font-weight:600; text-decoration: underline;\">Unchecked - 4 panels<br/></span>Zoom each corner separately.</p><p style='white-space:pre'><span style=\" font-weight:600; text-decoration: underline;\">Indeterminate - 2 panels<br/></span>Zoom only the top and bottom of the page.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Checked - 4 high-quality panels<br/></span>Zoom each corner separately. Try to increase the quality of magnification. Check wiki for more details.</p></body></html>": "<html><head/><body><p style='white-space:pre'><span style=\" font-weight:600; text-decoration: underline;\">Sin marcar - 4 paneles<br/></span>Zoom 4 esquinas.</p><p style='white-space:pre'><span style=\" font-weight:600; text-decoration: underline;\">Gris - 2 paneles<br/></span>Zoom 2 secciones.</p><p><span style=\" font-weight:600; text-decoration: underline;\">Marcado - 4 HQ panesls<br/></span>Zoom alta res.</p></body></html>",
    "Panel View 4/2/HQ": "Panel Kindle 4/2/HQ",
    "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Unchecked - JPEG<br/></span>Use JPEG files</p><p><span style=\" font-weight:600; text-decoration: underline;\">Indeterminate - force PNG<br/></span>Create PNG files instead JPEG for black and white images</p><p><span style=\" font-weight:600; text-decoration: underline;\">Checked - mozJpeg<br/></span>10-20% smaller JPEG file, with the same image quality, but processing time multiplied by 2</p></body></html>": "<html><head/><body><p><span style=\" font-weight:600; text-decoration: underline;\">Sin marcar - JPEG<br/></span>Fuerza JPEG</p><p><span style=\" font-weight:600; text-decoration: underline;\">Gris - forzar PNG<br/></span>Fuerza PNG</p><p><span style=\" font-weight:600; text-decoration: underline;\">Marcado - mozJpeg<br/></span>Súper ligero JPEG</p></body></html>",
    "JPEG/PNG/mozJpeg": "JPEG/PNG/mozJpeg",
