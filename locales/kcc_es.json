    "Rainbow eraser": "Borrar arcoiris",
    "<html><head/><body><p>Combines all selected files into a single file. (Helpful for combining chapters into volumes.)</p></body></html>": "<html><head/><body><p>Combina todo al convertir.</p></body></html>",
